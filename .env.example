# SMTP2GO contact-form and quote-wizard configuration.
# These are NOT read from this file in production — set them in the
# Netlify dashboard: Site settings → Environment variables.

# SMTP2GO API key (Settings → API Keys in the SMTP2GO dashboard)
SMTP2GO_API_KEY=api-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Verified sender address — the domain must be verified in SMTP2GO
SMTP2GO_SENDER=web@adpacc.sk

# Where form submissions are delivered
CONTACT_FORM_RECIPIENT=office@adpacc.sk

# Google reCAPTCHA v3 configuration.
# Both site key and secret key must be set to enable reCAPTCHA v3 verification.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-XXXXXXXX
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-XXXXXXXX
